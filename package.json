{
  "name": "chronicle",
  "version": "0.1.0",
  "description": "Local-first capture, reviewed Markdown memory, and evidence-grounded recall for small teams",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node scripts/copy-web-assets.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx test/*.test.ts src/web/*.test.ts",
    "test:coverage": "node --experimental-test-coverage --test --import tsx test/*.test.ts src/web/*.test.ts",
    "start": "node dist/index.js",
    "start:web": "node dist/web/server.js",
    "dev": "tsx src/index.ts",
    "ingest": "tsx src/ingest.ts",
    "index": "tsx src/index-cli.ts",
    "recall": "tsx src/recall-cli.ts",
    "review": "tsx src/review-cli.ts",
    "web": "tsx src/web/server.ts",
    "doctor": "tsx src/doctor.ts",
    "maintain": "tsx src/maintenance.ts",
    "digest": "tsx src/digest.ts",
    "smoke:web": "node scripts/smoke-web.mjs",
    "check": "npm run typecheck && npm test && npm run build && npm run smoke:web"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@discordjs/voice": "^0.19.2",
    "@mozilla/readability": "^0.6.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "libsodium-wrappers": "^0.8.4",
    "linkedom": "^0.18.13",
    "opusscript": "^0.0.8",
    "prism-media": "^1.3.5",
    "undici": "^6.27.0",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  },
  "overrides": {
    "undici": "^6.27.0"
  }
}
