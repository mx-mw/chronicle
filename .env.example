# Chronicle starts closed. Copy this file to .env, then explicitly allow only
# the Discord server, channels, and identities that should record or recall.

# Discord application
DISCORD_TOKEN=
# Optional command registration scope. This speeds up development registration,
# but it is not an authorization rule.
GUILD_ID=

# Dedicated Chronicle Inbox (new messages only; no history or server scrape).
# When enabled, every non-bot message intentionally posted by an allowed
# identity in an allowed channel is encrypted, saved, and queued for processing.
DISCORD_INBOX_ENABLED=false
# Set true only after enabling Message Content under Privileged Gateway Intents
# in Discord's Developer Portal for this application.
DISCORD_MESSAGE_CONTENT_ENABLED=false
INBOX_GUILD_IDS=
INBOX_CHANNEL_IDS=
INBOX_USER_IDS=
INBOX_ROLE_IDS=
# Generate once with: openssl rand -base64 32
# Losing this key makes saved Inbox sources unreadable. Never commit it.
SOURCE_ENCRYPTION_KEY=
# Empty defaults to <KB_DIR>/.sources.
SOURCE_CATALOG_DIR=
# Required when Inbox mode is enabled. Expired content is discarded to a
# content-free tombstone while the provider message ID remains for idempotency.
INBOX_RETENTION_DAYS=
INBOX_MAX_ATTACHMENTS=10
INBOX_MAX_ATTACHMENT_BYTES=26214400
INBOX_MAX_TOTAL_ATTACHMENT_BYTES=52428800
INBOX_MAX_URLS=10
# Required public HTTPS pages for Discord API-data disclosure and user
# access/export, correction, and deletion requests.
DISCORD_PRIVACY_POLICY_URL=
DISCORD_DATA_REQUEST_URL=

# Capture and consent
AUTO_RECORD=false
CONSENT_GRACE_MS=10000
# Hard fail-safe bounds for forgotten/automatic calls. Raw Discord capture is
# 48 kHz stereo PCM, so byte use grows much faster than the compressed call.
MAX_RECORDING_MINUTES=180
MAX_SESSION_AUDIO_BYTES=8589934592
MIN_FREE_DISK_BYTES=5368709120
MAX_SESSION_SEGMENTS=5000
RECORD_GUILD_IDS=
RECORD_CHANNEL_IDS=
RECORD_USER_IDS=
RECORD_ROLE_IDS=

# Recall has a separate deny-by-default policy.
RECALL_GUILD_IDS=
RECALL_CHANNEL_IDS=
RECALL_USER_IDS=
RECALL_ROLE_IDS=

# Model output becomes searchable only after review unless explicitly disabled.
REQUIRE_REVIEW=true

# Distillation and recall: local keeps source content on this machine. Anthropic
# is an explicit opt-in and sends the relevant transcript/source or excerpts.
LLM_PROVIDER=local
LLM_BASE_URL=http://127.0.0.1:11434/v1
CHRONICLE_MODEL=qwen2.5:3b
LLM_API_KEY=
LLM_TIMEOUT_MS=1800000
LLM_JSON_MODE=true

# Only used when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_TIMEOUT_MS=1800000

# Embeddings default to a loopback endpoint and are refused remotely unless the
# escape hatch below is deliberately enabled.
EMBED_BASE_URL=http://127.0.0.1:11434/v1
EMBED_MODEL=nomic-embed-text
EMBED_TIMEOUT_MS=60000
RECALL_RELEVANCE_FLOOR=0.35
ALLOW_REMOTE_MODEL_ENDPOINTS=false

# Parakeet MLX and media processing
PARAKEET_BIN=parakeet-mlx
PARAKEET_MODEL=mlx-community/parakeet-tdt-0.6b-v3
PARAKEET_TIMEOUT_MS=1800000
FFMPEG_TIMEOUT_MS=1800000
FFMPEG_CONCURRENCY=4
MAX_MEDIA_MINUTES=240
YOUTUBE_TIMEOUT_MS=1800000
WEB_FETCH_TIMEOUT_MS=20000
DNS_LOOKUP_TIMEOUT_MS=5000
DNS_LOOKUP_CONCURRENCY=8
DNS_LOOKUP_QUEUE_LIMIT=32
COMMAND_TIMEOUT_MS=600000
HTTP_TIMEOUT_MS=60000
MAX_SOURCE_BYTES=2147483648
MAX_PDF_SOURCE_BYTES=104857600
MAX_TEXT_SOURCE_BYTES=26214400
MAX_WEB_SOURCE_BYTES=10485760
KEEP_INGEST_ARTIFACTS=false

# Storage and workspace defaults
KB_DIR=kb
SESSIONS_DIR=sessions
# For Discord captures, use the Discord guild ID here and in WEB_WORKSPACE_ID
# so CLI review and the browser Inbox open the same workspace.
WORKSPACE_ID=default
# Leave empty to derive <KB_DIR>/.index.db.
INDEX_PATH=
RAW_AUDIO_RETENTION_HOURS=72
CHRONICLE_TIMEZONE=Asia/Hong_Kong

# Durable processing queue and shutdown
PROCESSING_TIMEOUT_MS=1800000
PROCESSING_RETRIES=2
PROCESSING_QUEUE_LIMIT=25
SHUTDOWN_TIMEOUT_MS=30000

# Local web application. A non-loopback WEB_HOST requires WEB_AUTH_TOKEN;
# unspecified binds (0.0.0.0 or ::) also require exact WEB_ALLOWED_HOSTS.
WEB_HOST=127.0.0.1
WEB_PORT=4321
WEB_AUTH_TOKEN=
WEB_ALLOWED_HOSTS=
# Match WORKSPACE_ID (normally the Discord guild ID for Discord deployments).
# Remote encrypted-source routes are locked to this value and ignore workspace
# headers; the web bearer token does not grant multi-workspace switching.
WEB_WORKSPACE_ID=default
# Browser capture may read local files only below this realpath. Empty disables
# local-path web capture; URL capture still works.
WEB_INGEST_ROOT=
WEB_PREVIEW_TTL_MS=600000
WEB_PREVIEW_CACHE_LIMIT=8
