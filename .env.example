# Discord bot token — https://discord.com/developers/applications → Bot → Token
DISCORD_TOKEN=

# Optional: register slash commands to one server for instant availability
# (global registration can take up to an hour to propagate)
GUILD_ID=

# Local OpenAI-compatible server used for meeting distillation. Works with
# Ollama (`ollama serve`, default port 11434) or llama.cpp's `llama-server`
# (default port 8080) — point this at whichever you run.
LLM_BASE_URL=http://127.0.0.1:11434/v1

# Model name sent in the request — must match `ollama list` (or your
# llama-server's loaded model) exactly.
CHRONICLE_MODEL=qwen2.5:3b

# Optional: only needed if your server requires an API key
LLM_API_KEY=

# Parakeet MLX (uv tool install parakeet-mlx). Model auto-downloads from
# Hugging Face on first transcription.
PARAKEET_BIN=parakeet-mlx
PARAKEET_MODEL=mlx-community/parakeet-tdt-0.6b-v3

# Where the knowledge base and raw session audio live
KB_DIR=kb
SESSIONS_DIR=sessions
